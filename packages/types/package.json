{
  "name": "@kombe/types",
  "version": "1.0.0",
  "description": "Shared TypeScript types for SSCO (Kombe stack)",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "import": "./dist/index.mjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "clean": "rimraf dist",
    "lint": "tsc --noEmit",
    "test": "echo \"No tests yet\""
  },
  "keywords": [
    "typescript",
    "types",
    "shared"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "rimraf": "^5.0.5",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "zod": "^3.22.4"
  }
}
