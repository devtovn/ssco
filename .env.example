# Docker Compose Environment Variables
# Copy this file to .env and update with your actual values

# ===========================
# General Configuration
# ===========================
NODE_ENV=development
COMPOSE_PROJECT_NAME=price-comparison

# ===========================
# PostgreSQL Configuration
# ===========================
POSTGRES_USER=pricecompare
POSTGRES_PASSWORD=pricecompare_dev_password
POSTGRES_DB=price_comparison
POSTGRES_PORT=5432

# ===========================
# Redis Configuration
# ===========================
REDIS_PORT=6379

# ===========================
# Backend Configuration
# ===========================
BACKEND_PORT=4000

# JWT Configuration
JWT_SECRET=dev_jwt_secret_change_in_production
JWT_REFRESH_SECRET=dev_jwt_refresh_secret_change_in_production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# API Configuration
API_BASE_URL=http://localhost:4000
FRONTEND_URL=http://localhost:3000

# AI Service Configuration (OpenAI/Claude)
AI_SERVICE_PROVIDER=openai
OPENAI_API_KEY=
CLAUDE_API_KEY=

# E-commerce Platform API Keys
TIKI_API_KEY=
LAZADA_API_KEY=
LAZADA_API_SECRET=
TIKTOK_SHOP_API_KEY=

# Scraping Configuration
PROXY_SERVICE_URL=
SCRAPING_ENABLED=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================
# Frontend Configuration
# ===========================
FRONTEND_PORT=3000

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_FRONTEND_URL=http://localhost:3000

# Analytics Configuration
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Feature Flags
NEXT_PUBLIC_ENABLE_PWA=true
